<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Import File</title>
    <link rel="stylesheet" href="/styles/myTheme.css">
    <link rel="stylesheet" href="/styles/importFile.css">
</head>

<body>

    <!-- Container body -->
    <div class="row">

        <div class="glass-card">
            <div class="badge">
                <div class="dot"></div>
                Secure VCF Upload
            </div>
            <h1>Upload Your<br>
                Contacts File
            </h1>
            <p class="subtitle">Drag & drop your .json file below or browse from your device. Your file will be
                securely
                sent
                to the backend API.</p>
            <label for="vcfInFile" class="upload-box" id="vcfDragFile">
                <div class="upload-icon">📇</div>
                <div class="upload-title">Choose a .json File</div>
                <div class="upload-desc">Supports vCard contact files only</div>
            </label>
            <input type="file" id="vcfInFile" accept=".json">
            <div class="file-info" id="fileInfo">
                <div class="file-name" id="fileName"></div>
                <div class="file-size" id="fileSize"></div>
            </div>
            <button type="button" class="upload-btn" id="uploadBtn" disabled>Upload File</button>
            <div class="status" id="status"></div>
            <div class="footer"> Modern frontend • Glassmorpihsm UI</div>
        </div>
    </div>


    <script src="/scripts/utils.js"></script>
    <script src="/scripts/importFile.js"></script>

</body>

</html>